# Copy to backend/.env locally. On Render, set these in the dashboard (do not commit secrets).
#
# ENV=development | production | test
# PORT=8000
# PROJECT_NAME=Coopwise
# CLIENT_DOMAIN=http://localhost:3000
#   Production: exact frontend origin for CORS, e.g. https://your-app.vercel.app
# INVITE_CODE_PREFIX=CPW-INV-
# DOMAIN=http://localhost:8000
#   Production: public API URL, e.g. https://your-api.onrender.com
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
#   Render: use Internal Database URL from Postgres add-on (async driver as above).
# ALGORITHM=HS256
# APP_SECRET_KEY=  # long random string; required for JWT
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# REDIS_URL=redis://...
#   Render: Redis instance URL, or managed Redis provider.
# OPENAI_API_KEY=sk-...   # required for AI chat and generated insights
# OPENAI_CHAT_MODEL=gpt-4o-mini
# CASHRAMP_API_KEY=       # CashRamp GraphQL bearer (preferred)
# GEMINI_API_KEY=         # legacy fallback bearer if CASHRAMP_API_KEY unset (misnamed historically)
# RATE_LIMIT_RULES_PATH=app/rate_limit_rules.json

ENV=
PORT=
PROJECT_NAME=
CLIENT_DOMAIN=
INVITE_CODE_PREFIX=
DOMAIN=
DATABASE_URL=
ALGORITHM=HS256
APP_SECRET_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
REDIS_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
CASHRAMP_API_KEY=
GEMINI_API_KEY=
RATE_LIMIT_RULES_PATH=
